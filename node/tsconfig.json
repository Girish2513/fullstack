{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,

    "rootDir": "./src",
    "outDir": "./dist",

    "baseUrl": "./src",

    "paths": {
      "@utils/*": ["utils/*"]
    },

    "strict": true,
    "sourceMap": true
  },

  "include": ["src/**/*", "../express"],
  "exclude": ["node_modules"]
}
