{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "outDir": "dist",
    "types": ["node"],
    "noUncheckedIndexedAccess": true,
    "baseUrl": "./src",
    "paths": {
      "@drills/*": ["src/drills/*"]
    }
  },
  "include": ["src"]
}
